{
  "name": "arbetsyta",
  "version": "0.1.0",
  "description": "Personal workspace app for markdown notes and project management",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mickekring/MK-Work-Tool.git"
  },
  "keywords": [
    "electron",
    "workspace",
    "markdown",
    "notes"
  ],
  "author": "Micke",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/markdown": "^1.6.3",
    "clsx": "^2.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  }
}
